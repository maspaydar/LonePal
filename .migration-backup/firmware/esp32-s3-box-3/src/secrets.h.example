// Copy this file to `secrets.h` (in the same directory) and fill in the
// values. `secrets.h` is intentionally NOT committed.

#pragma once

#define WIFI_SSID          "your-wifi-ssid"
#define WIFI_PASSWORD      "your-wifi-password"

// Public host of the HeyGrand SaaS (no scheme, no trailing slash).
#define HEYGRAND_HOST      "your-app.replit.app"

// 1 = use https/wss (production), 0 = use http/ws (local dev).
#define HEYGRAND_USE_TLS   1

// Must exactly match `DEVICE_HMAC_SECRET` in the server's environment.
// Generate a strong random value (e.g. `openssl rand -hex 32`).
#define DEVICE_HMAC_SECRET "REPLACE_ME_WITH_SHARED_HMAC_SECRET"

// Optional: firmware version reported in DEVICE_STATUS.
#define HEYGRAND_FW_VERSION "1.0.0"
