{
  "expo": {
    "name": "EchoPath Companion",
    "slug": "echopath-companion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "echopath",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#1a365d"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.echopath.companion"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a365d"
      },
      "package": "com.echopath.companion"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
