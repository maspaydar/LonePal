# HeyGrand — required environment variables.
# Copy to `.env` and fill in values. NEVER commit real secrets.
# Values are read exclusively from process.env; nothing here should be hardcoded in source.

# ── Core ─────────────────────────────────────────────────────────────────────
DATABASE_URL=            # Postgres connection string
SESSION_SECRET=          # Signing secret for all JWT auth (company/mobile/super-admin) + maintenance HMAC
NODE_ENV=                # "development" | "production"
APP_URL=                 # Public base URL of the frontend (used for CORS allow-list + email links)
LOG_LEVEL=               # pino log level (e.g. info, debug)

# ── AI (Gemini) ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=                    # Google Gemini API key (direct)
AI_INTEGRATIONS_GEMINI_API_KEY=    # Gemini key via Replit AI Integrations proxy (alternative)
AI_INTEGRATIONS_GEMINI_BASE_URL=   # Base URL for the AI Integrations proxy
AI_KEY_ENCRYPTION_SECRET=          # Secret used to encrypt provider API keys at rest (falls back to DEVICE_HMAC_SECRET)

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ── Device / sensor integrations ─────────────────────────────────────────────
DEVICE_HMAC_SECRET=      # HMAC secret for signed ESP32 device config (required in production)
ADT_WEBHOOK_SECRET=      # HMAC secret for verifying ADT webhook payloads

# ── Security / admin ─────────────────────────────────────────────────────────
VPC_AUTH_TOKEN=              # Shared token expected on internal VPC-only routes
SUPER_ADMIN_BOOTSTRAP_TOKEN= # One-time token allowing the first super-admin to register
SUPER_ADMIN_RESET_TOKEN=     # Token for the super-admin emergency reset flow
SEED_SECRET=                 # Guards seed/demo data endpoints

# ── Replit-provided (auto-injected in the Replit environment) ─────────────────
# PORT, BASE_PATH, REPLIT_DOMAINS, REPLIT_DEV_DOMAIN, REPL_ID, REPL_IDENTITY,
# WEB_REPL_RENEWAL, REPLIT_CONNECTORS_HOSTNAME — no need to set these manually.
